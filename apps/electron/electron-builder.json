{
  "appId": "com.localmind.app",
  "productName": "LocalMind",
  "directories": {
    "output": "dist_electron"
  },
  "publish": {
    "provider": "github",
    "owner": "satiricalguru",
    "repo": "Local-Mind"
  },
  "files": [
    "dist/**/*",
    "assets/**/*",
    "package.json",
    {
      "from": "../../packages/registry-schema/dist",
      "to": "packages/registry-schema/dist"
    },
    {
      "from": "../../packages/shared-types/dist",
      "to": "packages/shared-types/dist"
    },
    {
      "from": "../../apps/renderer/dist",
      "to": "renderer/dist"
    }
  ],
  "mac": {
    "target": "dmg",
    "icon": "assets/icon.png"
  },
  "win": {
    "target": "nsis",
    "icon": "assets/icon.png"
  }
}
