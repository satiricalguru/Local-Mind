{
  "name": "localmind-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "Every model. Your machine.",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "package": "pnpm build && pnpm --filter @localmind/electron exec electron-builder"
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
